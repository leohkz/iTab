{
  "manifest_version": 3,
  "name": "Workspace New Tab",
  "description": "A macOS and iPadOS inspired browser workspace for Chrome's new tab page.",
  "version": "0.1.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "bookmarks", "tabs"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "webview": {},
  "content_security_policy": {
    "extension_pages": "script-src 'self'; frame-src https://www.youtube.com https://open.spotify.com;"
  }
}
