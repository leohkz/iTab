{
  "manifest_version": 3,
  "name": "Workspace New Tab",
  "description": "A macOS and iPadOS inspired browser workspace for Chrome's new tab page.",
  "version": "0.1.0",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "bookmarks", "tabs"],
  "host_permissions": [
    "https://github.com/",
    "https://api.github.com/"
  ],
  "optional_host_permissions": ["*://*/*"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
